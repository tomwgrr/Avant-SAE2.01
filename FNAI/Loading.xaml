<Window x:Class="FNAI.Loading"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FNAI"
        mc:Ignorable="d"
        Title="FNAI"
        WindowStyle="None"
        WindowState="Maximized"
        Background="Black"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Storyboard x:Key="WarningBlink" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BlinkText"
                                           Storyboard.TargetProperty="Opacity"
                                           RepeatBehavior="Forever">
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:0.5" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="0:0:1.0" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="1920" Height="1080">

            <!-- PHASE 1 : WARNING -->
            <Grid x:Name="WarningScreen" Background="Black" Panel.ZIndex="10">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                    <Border Width="900" Height="4" Background="White" Margin="0,0,0,40"/>

                    <TextBlock Text="AVERTISSEMENT "
                               FontFamily="pack://application:,,,/Assets/#Five Fonts at Freddy's"
                               FontSize="52"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,40"/>

                    <TextBlock Width="860"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               FontFamily="pack://application:,,,/Assets/#Five Fonts at Freddy's"
                               FontSize="24"
                               Foreground="White"
                               LineHeight="38"
                               Margin="0,0,0,40">
                        Ce jeu contient des <Run Foreground="#FF4400" FontWeight="Bold">flashs lumineux intenses</Run>,
                        des <Run Foreground="#FF4400" FontWeight="Bold">jumpscares</Run> sonores et visuels,
                        ainsi que des images susceptibles de provoquer une
                        <Run Foreground="#FF4400" FontWeight="Bold">photosensibilité</Run>.
                        <LineBreak/><LineBreak/>
                        Si vous souffrez d'épilepsie ou d'une condition similaire,
                        veuillez ne pas jouer.
                    </TextBlock>

                    <TextBlock x:Name="BlinkText"
                               Text="[ APPUYEZ SUR UNE TOUCHE POUR CONTINUER ]"
                               FontFamily="pack://application:,,,/Assets/#Five Fonts at Freddy's"
                               FontSize="22"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,40"/>

                    <Border Width="900" Height="4" Background="White"/>

                </StackPanel>
            </Grid>

            <!-- PHASE 2 : LOGO -->
            <StackPanel x:Name="LogoPanel"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Opacity="0"
                        Panel.ZIndex="9">
                <TextBlock Text="LOCUFIER SAHIN WAGNER"
                           FontFamily="pack://application:,,,/Assets/#Five Fonts at Freddy's"
                           FontSize="32"
                           Foreground="#333333"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock FontFamily="pack://application:,,,/Assets/#Five Fonts at Freddy's"
                           FontSize="200"
                           FontWeight="Bold"
                           HorizontalAlignment="Center">
                    <Run Text="IUT :" Foreground="#888888"/>
                    <Run Text="SN" Foreground="#CC1100"/>
                </TextBlock>
                <TextBlock Text="IUT : Simonet's Night"
                           FontFamily="pack://application:,,,/Assets/#Five Fonts at Freddy's"
                           FontSize="28"
                           Foreground="#333333"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"/>
            </StackPanel>

            <!-- Flash overlay -->
            <Rectangle x:Name="FlashOverlay" Fill="White" Opacity="0"
                       IsHitTestVisible="False" Panel.ZIndex="200"/>

        </Grid>
    </Viewbox>

</Window>
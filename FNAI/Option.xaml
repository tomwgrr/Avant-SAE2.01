<Window x:Class="FNAI.Option"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FNAI"
        mc:Ignorable="d"
        Title="FNAI"
        WindowStyle="None"
        WindowState="Maximized">

    <Viewbox Stretch="Uniform">
        <Grid Width="1920" Height="1080">

            <!-- Fond -->
            <Grid Background="Black">
                <!-- Vignette radiale -->
                <Rectangle>
                    <Rectangle.Fill>
                        <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5"
                                             RadiusX="0.6" RadiusY="0.6">
                            <GradientStop Color="#00000000" Offset="0.45"/>
                            <GradientStop Color="#CC000000" Offset="1.0"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
            </Grid>

            <!-- Titre Settings -->
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="48,100,0,0">
                <Label x:Name="title1" Content="Settings :"
                       Background="Transparent" Foreground="White"
                       FontSize="96"
                       FontFamily="pack://application:,,,/Assets/#Five Fonts at Freddy's" Height="150"/>
            </StackPanel>

            <!-- Contenu principal : 3 blocs IMG + flèches -->
            <Grid>
                <Grid.Resources>
                    <Style x:Key="MenuButtonStyle" TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontSize" Value="48"/>
                        <Setter Property="Height" Value="100"/>
                        <Setter Property="Padding" Value="20,10"/>
                        <Setter Property="Margin" Value="0,0,0,0"/>
                        <Setter Property="HorizontalAlignment" Value="Left"/>
                        <Setter Property="FontFamily" Value="pack://application:,,,/Assets/#Five Fonts at Freddy's"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="Red" BlurRadius="20" ShadowDepth="0" Opacity="0.9"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <!-- Style flèche (petit, blanc, hover rouge glow) -->
                    <Style x:Key="ArrowButtonStyle" TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontSize" Value="52"/>
                        <Setter Property="Width" Value="70"/>
                        <Setter Property="Height" Value="70"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="FontFamily" Value="pack://application:,,,/Assets/#Five Fonts at Freddy's"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent" BorderThickness="0" Padding="0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="Red" BlurRadius="20" ShadowDepth="0" Opacity="0.9"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <!-- Style valeur (label numérique central) -->
                    <Style x:Key="ValueLabelStyle" TargetType="Label">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontSize" Value="48"/>
                        <Setter Property="Width" Value="120"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="FontFamily" Value="pack://application:,,,/Assets/#Five Fonts at Freddy's"/>
                    </Style>
                </Grid.Resources>

                <!-- Les 3 blocs centrés horizontalement -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,-60,0,0">

                    <!-- ===== BLOC 1 ===== -->
                    <StackPanel Orientation="Vertical" Margin="60,0">
                        <Border Width="320" Height="320"
                                BorderBrush="White" BorderThickness="3"
                                Background="Transparent">
                            <Image x:Name="block1Image"
                                   Source="/Assets/freddy.jpeg"
                                   Stretch="UniformToFill"/>
                        </Border>
                        <!-- Flèches + valeur -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <Button x:Name="block1Left"  Content="&lt;" Style="{StaticResource ArrowButtonStyle}" Click="Block1Left_Click"/>
                            <Label x:Name="block1Value" Content="1" Style="{StaticResource ValueLabelStyle}"/>
                            <Button x:Name="block1Right" Content="&gt;" Style="{StaticResource ArrowButtonStyle}" Click="Block1Right_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- ===== BLOC 2 ===== -->
                    <StackPanel Orientation="Vertical" Margin="60,0">
                        <Border Width="320" Height="320"
                                BorderBrush="White" BorderThickness="3"
                                Background="Transparent">
                            <Image x:Name="block2Image"
                                   Source="pack://application:,,,/Assets/img2_0.png"
                                   Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <Button x:Name="block2Left"  Content="&lt;" Style="{StaticResource ArrowButtonStyle}" Click="Block2Left_Click"/>
                            <Label x:Name="block2Value" Content="0" Style="{StaticResource ValueLabelStyle}"/>
                            <Button x:Name="block2Right" Content="&gt;" Style="{StaticResource ArrowButtonStyle}" Click="Block2Right_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- ===== BLOC 3 ===== -->
                    <StackPanel Orientation="Vertical" Margin="60,0">
                        <Border Width="320" Height="320"
                                BorderBrush="White" BorderThickness="3"
                                Background="Transparent">
                            <Image x:Name="block3Image"
                                   Source="pack://application:,,,/Assets/img3_0.png"
                                   Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <Button x:Name="block3Left"  Content="&lt;" Style="{StaticResource ArrowButtonStyle}" Click="Block3Left_Click"/>
                            <Label x:Name="block3Value" Content="2" Style="{StaticResource ValueLabelStyle}"/>
                            <Button x:Name="block3Right" Content="&gt;" Style="{StaticResource ArrowButtonStyle}" Click="Block3Right_Click"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>

                <!-- Bouton Back en bas à gauche -->
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="80,100,0,60">
                    <Button x:Name="exitButton" Content="Back" Style="{StaticResource MenuButtonStyle}" Click="Back"/>
                </StackPanel>

            </Grid>

        </Grid>
    </Viewbox>

</Window>

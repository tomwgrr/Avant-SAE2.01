<UserControl x:Class="FNAI.PopupInvasion"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FNAI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border BorderBrush="Black" BorderThickness="2" Background="LightGray" CornerRadius="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <Grid Grid.Row="0" Background="DarkBlue">
                <TextBlock Text="VOUS AVEZ UN NOUVEAU VIRUS ! (petit cadeau de Anatole)" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="Bold"/>


                <Button Content="X" Width="20" Height="20" HorizontalAlignment="Right" Margin="0,0,5,0"
                        Background="Red" Foreground="White" FontWeight="Bold" Click="BoutonCroix_Click"/>
            </Grid>
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,10">
                    Anatole: Bonjour Monsieur,
                    <LineBreak/>
                    Je vous envoie comme promis le travail que j'ai effectué sur le projet
                    <LineBreak/>
                    des presques 24 heures de travail acharné pour vous faire plaisir.
                </TextBlock>
                <TextBlock x:Name="TxtVies" Text="Nombre : 1" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

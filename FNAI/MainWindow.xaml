<Window x:Class="FNAI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FNAI"
        mc:Ignorable="d"
        Title="FNAI"
        WindowStyle="None"
        WindowState="Maximized">

    <Viewbox Stretch="Uniform">
        <Grid Width="1920" Height="1080">

            <!-- Fond -->
            <Grid Background="Black">

                <!-- Image de fond -->
                <Image Source="Assets/menu.png"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Right"
                       Width="1250"/>

                <!-- Dégradé noir gauche -->
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="0.75,0.5">
                            <GradientStop Color="#FF000000" Offset="0.0"/>
                            <GradientStop Color="#FF000000" Offset="0.28"/>
                            <GradientStop Color="#E0000000" Offset="0.48"/>
                            <GradientStop Color="#66000000" Offset="0.72"/>
                            <GradientStop Color="#00000000" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Vignette radiale -->
                <Rectangle>
                    <Rectangle.Fill>
                        <RadialGradientBrush GradientOrigin="2.5,0.5" Center="0.5,0.5"
                                             RadiusX="0.6" RadiusY="0.6">
                            <GradientStop Color="#00000000" Offset="0.45"/>
                            <GradientStop Color="#CC000000" Offset="1.0"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

            </Grid>
            <Label x:Name="title4" Content="LOCUFIER SAHIN WAGNER"
                       Background="Transparent" Foreground="White"
                       FontSize="32"
                       FontFamily="pack://application:,,,/Assets/#Five Fonts at Freddy's" Height="50" Margin="1430,1020,10,10" Width="480"/>
            <Label x:Name="title5" Content="v0.0.01"
                       Background="Transparent" Foreground="White"
                       FontSize="32"
                       FontFamily="pack://application:,,,/Assets/#Five Fonts at Freddy's" Height="50" Margin="1760,965,10,65" Width="150"/>
            <!-- Titres -->
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="48,50,0,0">
                <Label x:Name="title1" Content="IUT :"
                       Background="Transparent" Foreground="White"
                       FontSize="96"
                       FontFamily="pack://application:,,,/Assets/#Five Fonts at Freddy's" Height="150"/>
                <Label x:Name="title2" Content="Simonet's"
                       Background="Transparent" Foreground="White"
                       FontSize="96"
                       FontFamily="pack://application:,,,/Assets/#Five Fonts at Freddy's" Height="150"/>
                <Label x:Name="title3" Content="Night"
                       Background="Transparent" Foreground="White"
                       FontSize="96"
                       FontFamily="pack://application:,,,/Assets/#Five Fonts at Freddy's" Height="150"/>
            </StackPanel>

            <Grid>

                <Grid.Resources>
                    <Style x:Key="MenuButtonStyle" TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontSize" Value="48"/>
                        <Setter Property="Height" Value="100"/>
                        <Setter Property="Padding" Value="20,10"/>
                        <Setter Property="Margin" Value="0,0,0,0"/>
                        <Setter Property="HorizontalAlignment" Value="Left"/>

                        <Setter Property="FontFamily" Value="pack://application:,,,/Assets/#Five Fonts at Freddy's"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                BorderBrush="Transparent" 
                                BorderThickness="0" 
                                Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#FFFFFF"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="White" BlurRadius="20" ShadowDepth="0" Opacity="0.9"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Grid.Resources>

                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="80,100,0,60">
                    <Button x:Name="startButton" Content="Play" Style="{StaticResource MenuButtonStyle}" MouseEnter="Selected" MouseLeave="Unselect" Click="StartGame"/>
                    <Button x:Name="loadButton" Content="Load" Style="{StaticResource MenuButtonStyle}" MouseEnter="Selected" MouseLeave="Unselect"/>
                    <Button x:Name="optionsButton" Content="Options" Style="{StaticResource MenuButtonStyle}" Click="OpenSettings" MouseEnter="Selected" MouseLeave="Unselect"/>
                    <Button x:Name="exitButton" Content="Exit" Style="{StaticResource MenuButtonStyle}" Click="End" MouseEnter="Selected" MouseLeave="Unselect"/>
                </StackPanel>
            </Grid>

        </Grid>
    </Viewbox>

</Window>